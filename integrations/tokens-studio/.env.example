# PDS to publish to (required)
ATP_SERVICE=https://bsky.social

# atproto credentials (required)
ATP_IDENTIFIER=handle.bsky.social
ATP_PASSWORD=app-password-here

# Record key for the tokenCollection
ATP_RECORD_KEY=latest

# Path to a single export file, OR a directory of token files
# TS_TOKEN_FILE=./tokens.json
# TS_TOKEN_DIR=./tokens/
