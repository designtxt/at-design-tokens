# PDS to publish to (required)
ATP_PDS_HOST=https://bsky.social

# atproto credentials (required)
ATP_USERNAME=handle.bsky.social
ATP_PASSWORD=app-password-here

# Record key for the tokenCollection
ATP_RECORD_KEY=terrazzo

# Path to DTCG token file(s)
TERRAZZO_TOKEN_DIR=./tokens

# Remote poll interval in milliseconds (default: 30000)
# SYNC_INTERVAL=30000
